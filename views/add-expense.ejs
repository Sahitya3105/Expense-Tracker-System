<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Expense – Expense Tracker</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=Space+Mono:wght@400;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body style="align-items:center;">

  <div class="container form-container">

    <div style="margin-bottom:1rem;">
      <a href="/" class="btn btn-secondary" style="padding:0.45rem 1rem; font-size:0.85rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back
      </a>
    </div>

    <div class="glass-panel">

      <!-- Header -->
      <div style="text-align:center; margin-bottom:2.25rem; padding-bottom:1.75rem; border-bottom:1px solid var(--border);">
        <div style="display:inline-flex; align-items:center; justify-content:center; width:58px; height:58px; border-radius:10px; background:var(--orange-dim); border:1px solid var(--orange-border); font-size:1.7rem; margin-bottom:1rem;">➕</div>
        <h1>Add Expense</h1>
        <p class="subtitle" style="margin-top:0.4rem;">Record a new transaction.</p>
      </div>

      <form action="/add-expense" method="POST" class="expense-form" id="add-expense-form">

        <div class="form-group">
          <label for="title">Description / Title</label>
          <input type="text" id="title" name="title" required placeholder="e.g. Lunch at Cafe" class="form-control">
        </div>

        <div class="row">
          <div class="form-group col-6">
            <label for="amount">Amount (₹)</label>
            <input type="number" step="0.01" min="0" id="amount" name="amount" required placeholder="0.00" class="form-control">
          </div>
          <div class="form-group col-6">
            <label for="expense_date">Date</label>
            <input type="date" id="expense_date" name="expense_date" required class="form-control"
              value="<%= new Date().toISOString().split('T')[0] %>">
          </div>
        </div>

        <div class="form-group">
          <label for="category_id">Category</label>
          <div class="custom-select-wrapper">
            <select id="category_id" name="category_id" required class="form-control custom-select">
              <option value="" disabled selected>Select a category</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>"><%= cat.category_name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="mt-lg">
          <button type="submit" id="submit-btn" class="btn btn-primary btn-block">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Save Expense
          </button>
        </div>

      </form>
    </div>
  </div>

</body>
</html>
