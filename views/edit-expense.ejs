<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Expense - Expense Tracker</title>
    <!-- Modern Font: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Premium Stylesheet -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="bg-shape shape-2"></div>
    <div class="bg-shape shape-3"></div>
    
    <div class="container glass-panel form-container">
        <header class="header mb-lg">
            <div>
                <h1>Edit Expense</h1>
                <p class="subtitle">Modify transaction details.</p>
            </div>
            <a href="/" class="btn btn-secondary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                Back
            </a>
        </header>

        <form action="/edit/<%= expense.id %>" method="POST" class="expense-form">
            <div class="form-group">
                <label for="title">Description / Title</label>
                <input type="text" id="title" name="title" required value="<%= expense.title %>" class="form-control">
            </div>

            <div class="row">
                <div class="form-group col-6">
                    <label for="amount">Amount (&#8377;)</label>
                    <input type="number" step="0.01" id="amount" name="amount" required value="<%= expense.amount %>" class="form-control">
                </div>
                <div class="form-group col-6">
                    <label for="expense_date">Date</label>
                    <input type="date" id="expense_date" name="expense_date" required value="<%= expense.expense_date %>" class="form-control">
                </div>
            </div>

            <div class="form-group">
                <label for="category_id">Category</label>
                <div class="custom-select-wrapper">
                    <select id="category_id" name="category_id" required class="form-control custom-select">
                        <option value="" disabled>Select a category</option>
                        <% categories.forEach(category => { %>
                            <option value="<%= category.id %>" <%= expense.category_id === category.id ? 'selected' : '' %>>
                                <%= category.category_name %>
                            </option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <div class="form-actions mt-lg">
                <button type="submit" class="btn btn-primary btn-block">Update Expense</button>
            </div>
        </form>
    </div>
</body>
</html>
